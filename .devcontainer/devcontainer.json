{
  "name": "CheckMate2",
  "image": "mcr.microsoft.com/devcontainers/dotnet:1-10.0",
  "features": {
    "ghcr.io/devcontainers/features/node:1": {
      "version": "20"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-dotnettools.csdevkit",
        "dbaeumer.vscode-eslint"
      ]
    }
  },
  "postCreateCommand": "dotnet restore && cd frontend && npm ci",
  "forwardPorts": [5269, 5173]
}
